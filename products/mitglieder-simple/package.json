{
  "name": "@codefabrik/mitglieder-simple",
  "version": "0.5.0",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "Mitglieder Lokal — Mitgliederverwaltung fuer Vereine (Electron + Svelte Desktop-App)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:1420 && cross-env VITE_DEV_SERVER_URL=http://localhost:1420 electron .\"",
    "electron:build": "vite build && electron-builder --publish never",
    "test": "node --test tests/test_*.js"
  },
  "dependencies": {
    "@codefabrik/electron-platform": "workspace:*",
    "@codefabrik/shared": "workspace:*",
    "@codefabrik/vereins-shared": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "pdfmake": "^0.2.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "playwright": "^1.58.2",
    "sql.js": "^1.14.1",
    "svelte": "^5.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "de.detmers-publish.mitglieder-simple",
    "productName": "Mitglieder Lokal",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/icons/**/*",
      "node_modules/@codefabrik/electron-platform/**/*",
      "node_modules/@codefabrik/shared/**/*",
      "node_modules/@codefabrik/vereins-shared/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icons/icon.ico"
    },
    "directories": {
      "output": "release"
    }
  }
}
