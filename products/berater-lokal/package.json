{
  "name": "berater-lokal",
  "version": "0.1.0",
  "description": "Berater Lokal — Ganzheitliche Beratungssoftware fuer Finanz- und Versicherungsberater",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:1420 && cross-env VITE_DEV_SERVER_URL=http://localhost:1420 electron .\"",
    "build": "vite build",
    "electron:build": "vite build && electron-builder --publish never",
    "start": "vite build && electron .",
    "test": "node --test tests/test_*.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "svelte": "^5.0.0",
    "vite": "^6.0.7",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "de.detmers-publish.berater-lokal",
    "productName": "Berater Lokal",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Office"
    },
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.business"
    },
    "directories": {
      "output": "release"
    }
  }
}
