{
  "name": "@codefabrik/finanz-rechner",
  "version": "0.2.0",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "FinanzRechner Lokal — Finanzrechner fuer Versicherungsmakler (Electron + Svelte Desktop-App)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:1421 && cross-env VITE_DEV_SERVER_URL=http://localhost:1421 electron .\"",
    "electron:build": "vite build && electron-builder --publish never",
    "test": "node --test tests/test_*.js"
  },
  "dependencies": {
    "@codefabrik/electron-platform": "workspace:*",
    "@codefabrik/shared": "workspace:*",
    "pdfmake": "^0.2.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "svelte": "^5.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "de.detmers-publish.finanzrechner-lokal",
    "productName": "FinanzRechner Lokal",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "app.config.cjs",
      "assets/icons/**/*",
      "node_modules/@codefabrik/electron-platform/**/*",
      "node_modules/@codefabrik/shared/**/*"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icons/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icons/128x128.png",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icons/icon.ico"
    },
    "directories": {
      "output": "release"
    }
  }
}
