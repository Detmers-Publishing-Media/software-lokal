#!/bin/bash
# OpenClaw Poller v0.6.1 — 5-Phasen Pipeline mit Review-Loop + Governance
set -Eeuo pipefail

on_err() {
  local rc=$?
  log "ERR rc=$rc line=$1 cmd=${2:-unknown}" 2>/dev/null || true
  exit "$rc"
}
trap 'on_err "$LINENO" "$BASH_COMMAND"' ERR

LOGFILE=/var/log/openclaw-poller.log
LOCK_FILE=/tmp/openclaw-poller.lock
FORGEJO_URL="http://localhost:3000"
FORGEJO_ORG="{{ factory_org }}"
PROCESS_REPO="{{ process_repo }}"
PRODUCT_REPO="{{ product_repo }}"
FACTORY_VERSION="{{ factory_version }}"
HOLDER_ID="poller-$(hostname)-$$"

# Pflicht-Variablen pruefen
: "${FORGEJO_API_TOKEN:?FORGEJO_API_TOKEN fehlt — EnvironmentFile pruefen}"

log() {
  local ts msg
  ts="$(date '+%Y-%m-%d %H:%M:%S')"
  msg="[$ts] $*"
  printf '%s\n' "$msg" >&2
  printf '%s\n' "$msg" >> "$LOGFILE" || true
}

# ─── PID-Lock ──────────────────────────────────────────────────────────────
if [ -f "$LOCK_FILE" ]; then
  OLD_PID=$(cat "$LOCK_FILE" 2>/dev/null || echo "0")
  if kill -0 "$OLD_PID" 2>/dev/null; then
    log "Poller läuft bereits (PID $OLD_PID) — überspringe"
    exit 0
  else
    log "Veraltetes Lock-File (PID $OLD_PID tot) — entferne"
    rm -f "$LOCK_FILE"
  fi
fi
echo $$ > "$LOCK_FILE"
cleanup() {
  rm -f "$LOCK_FILE"
  docker exec factory-postgres psql -U forgejo -d forgejo -tAq -c \
    "DELETE FROM leader_lock WHERE holder_id='$HOLDER_ID'" 2>/dev/null || true
}
trap cleanup EXIT

log "=== Poller v$FACTORY_VERSION gestartet (PID $$) ==="

# ─── DB-Verfügbarkeit (fail-closed) ────────────────────────────────────────
if ! docker exec factory-postgres pg_isready -U forgejo -q 2>/dev/null; then
  log "FEHLER: PostgreSQL nicht erreichbar — fail-closed"
  exit 1
fi

# ─── SQL/Docker-Helfer ────────────────────────────────────────────────────────
sql_escape() {
  printf "%s" "$1" | sed "s/'/''/g"
}

run_psql() {
  docker exec factory-postgres psql -U forgejo -d forgejo -v ON_ERROR_STOP=1 -tAq "$@"
}

get_scalar_sql() {
  local sql="$1"
  local out
  if ! out="$(run_psql -c "$sql" 2>/tmp/openclaw-psql.err)"; then
    log "FEHLER: psql fehlgeschlagen: $(head -c 300 /tmp/openclaw-psql.err 2>/dev/null)"
    return 1
  fi
  printf '%s' "$out" | tr -d '[:space:]'
}

# ─── Kill Switch (runtime_control) ─────────────────────────────────────────
JOBS_ENABLED=$(get_scalar_sql "SELECT jobs_enabled FROM runtime_control WHERE env_name='prod'" 2>/dev/null || printf '')

if [ "$JOBS_ENABLED" != "t" ]; then
  log "Kill Switch aktiv (jobs_enabled=$JOBS_ENABLED) — überspringe"
  exit 0
fi

# ─── Leader Lock (5 Min Lease) ─────────────────────────────────────────────
LOCK_ACQUIRED=$(get_scalar_sql "
  INSERT INTO leader_lock (lock_name, holder_id, expires_at)
  VALUES ('poller', '$(sql_escape "$HOLDER_ID")', NOW() + INTERVAL '5 minutes')
  ON CONFLICT (lock_name) DO UPDATE
    SET holder_id = '$(sql_escape "$HOLDER_ID")',
        acquired_at = NOW(),
        expires_at = NOW() + INTERVAL '5 minutes'
  WHERE leader_lock.expires_at < NOW()
  RETURNING holder_id;" 2>/dev/null || printf '')

if [ "$LOCK_ACQUIRED" != "$HOLDER_ID" ]; then
  log "Kein Leader Lock erworben — anderer Poller aktiv"
  exit 0
fi
log "Leader Lock erworben: $HOLDER_ID"

# ─── Hilfsfunktionen ───────────────────────────────────────────────────────
forgejo_api() {
  curl -sf \
    -H "Authorization: token $FORGEJO_API_TOKEN" \
    -H "Content-Type: application/json" \
    "$@"
}

update_poller_state() {
  local object_id="$1"
  local stage="$2"
  local commit_hash="${3:-}"
  run_psql -c "
    INSERT INTO poller_state (object_id, stage, commit_hash, updated_at)
    VALUES ('$(sql_escape "$object_id")', '$(sql_escape "$stage")', '$(sql_escape "$commit_hash")', NOW())
    ON CONFLICT (object_id) DO UPDATE
      SET stage = EXCLUDED.stage,
          commit_hash = EXCLUDED.commit_hash,
          updated_at = NOW();" >/dev/null 2>&1 || {
    log "WARN: update_poller_state fehlgeschlagen fuer $object_id/$stage"
    return 0
  }
}

get_poller_state() {
  local object_id="$1"
  local out
  if ! out="$(run_psql -c "SELECT stage FROM poller_state WHERE object_id='$(sql_escape "$object_id")'" 2>/dev/null)"; then
    log "WARN: get_poller_state fehlgeschlagen fuer $object_id"
    printf ''
    return 0
  fi
  printf '%s' "$out" | tr -d '[:space:]'
}

# ─── Retry mit Exponential Backoff ───────────────────────────────────────────
# Nutzung: retry_with_backoff MAX_RETRIES "Beschreibung" command arg1 arg2
retry_with_backoff() {
  local max_retries=$1
  local description=$2
  shift 2

  local attempt=0
  local wait_seconds=10  # 10s → 30s → 90s

  while [ $attempt -lt $max_retries ]; do
    attempt=$((attempt + 1))
    log "[$description] Versuch $attempt/$max_retries"

    if "$@"; then
      log "[$description] Erfolg nach Versuch $attempt"
      return 0
    fi

    if [ $attempt -lt $max_retries ]; then
      log "[$description] Fehlgeschlagen. Warte ${wait_seconds}s..."
      sleep $wait_seconds
      wait_seconds=$((wait_seconds * 3))
    fi
  done

  log "[$description] Fehlgeschlagen nach $max_retries Versuchen"
  return 1
}

log_poller_event() {
  local object_id="$1"
  local event="$2"
  local details="${3:-}"
  local details_short
  details_short="$(printf '%s' "$details" | head -c 500)"
  run_psql -c "
    INSERT INTO poller_events (object_id, event, details)
    VALUES (
      '$(sql_escape "$object_id")',
      '$(sql_escape "$event")',
      '$(sql_escape "$details_short")'
    );" >/dev/null 2>&1 || {
    log "WARN: log_poller_event fehlgeschlagen fuer $object_id/$event"
    return 0
  }
}

is_allowed_metric_field() {
  case "$1" in
    product|dispatched_at|in_progress_at|pr_created_at|merged_at|blocked_at|\
    total_duration_minutes|dev_duration_minutes|retry_count|blocked_reason|\
    review_iterations|review_started_at|review_completed_at|review_verdict|\
    story_type|lane|completed_at)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

record_metric() {
  local object_id="$1"
  local field="$2"
  local value="${3:-NOW()}"
  if ! is_allowed_metric_field "$field"; then
    log "WARN: unzulaessiges pipeline_metrics-Feld: $field"
    return 0
  fi
  run_psql -c "
    INSERT INTO pipeline_metrics (object_id, $field)
    VALUES ('$(sql_escape "$object_id")', $value)
    ON CONFLICT (object_id)
    DO UPDATE SET $field = $value;" >/dev/null 2>&1 || {
    log "WARN: record_metric fehlgeschlagen fuer $object_id/$field"
    return 0
  }
}

# ─── Story-Governance-Felder lesen ───────────────────────────────────────────
read_story_field() {
  local story_file="$1"
  local field="$2"
  local out
  out="$(
    (grep "^${field}:" "$story_file" 2>/dev/null || true) \
      | head -1 \
      | sed "s/^${field}:[[:space:]]*//" \
      | tr -d '"'"'" \
      | tr -d '[:space:]'
  )"
  printf '%s' "$out"
  return 0
}

read_story_governance() {
  local story_file="$1"
  STORY_TYPE="$(read_story_field "$story_file" "story_type" || printf '')"
  STORY_LANE="$(read_story_field "$story_file" "lane" || printf '')"
  FORCE_APPROVE="$(read_story_field "$story_file" "force_approve_allowed" || printf '')"
  AUTO_MERGE="$(read_story_field "$story_file" "auto_merge_allowed" || printf '')"
  FOUNDER_GATE="$(read_story_field "$story_file" "founder_gate_required" || printf '')"

  : "${STORY_TYPE:=product-fast}"
  : "${STORY_LANE:=fast}"
  : "${FORCE_APPROVE:=true}"
  : "${AUTO_MERGE:=true}"
  : "${FOUNDER_GATE:=false}"

  return 0
}

# ─── Phase 1: DISPATCH — Inbox → Backlog ───────────────────────────────────
log "--- Phase 1: dispatch ---"

WORK_DIR=$(mktemp -d)
trap 'rm -rf "$WORK_DIR"; cleanup' EXIT

# Process-Repo klonen
CLONE_URL="http://factory-admin:${FORGEJO_API_TOKEN}@localhost:3000/$FORGEJO_ORG/$PROCESS_REPO.git"
clone_process_repo() {
  git clone --quiet "$CLONE_URL" "$WORK_DIR/process" 2>/dev/null
}

if ! retry_with_backoff 3 "clone:process-repo" clone_process_repo; then
  log "FEHLER: Konnte Process-Repo nicht klonen nach 3 Versuchen"
  log_poller_event "SYSTEM" "clone_failed" "Process-Repo nicht erreichbar"
  exit 1
fi

cd "$WORK_DIR/process"
git config user.name "Factory Poller"
git config user.email "poller@factory.local"

INBOX_DIR="work/01-inbox"
BACKLOG_DIR="work/03-backlog"

# Stories aus Inbox verarbeiten
shopt -s nullglob
for story_file in "$INBOX_DIR"/*.yml; do
  story_id=$(basename "$story_file" .yml)
  current_stage=$(get_poller_state "$story_id")

  if [ -n "$current_stage" ] && [ "$current_stage" != "inbox" ]; then
    log "dispatch: $story_id bereits in Stage '$current_stage' — überspringe"
    continue
  fi

  log "dispatch: $story_id → backlog"

  # Produkt-Feld aus YAML lesen
  produkt=$( (grep '^produkt:' "$story_file" 2>/dev/null || true) | awk '{print $2}' | tr -d '"'"'" | tr -d '[:space:]')
  : "${produkt:=$PRODUCT_REPO}"
  if [ "$produkt" = "$PRODUCT_REPO" ]; then
    log "dispatch: $story_id hat kein produkt-Feld — verwende Default: $PRODUCT_REPO"
  fi

  # Governance-Felder lesen und validieren
  read_story_governance "$story_file"
  log "dispatch: $story_id — type=$STORY_TYPE lane=$STORY_LANE founder_gate=$FOUNDER_GATE"

  # Slow-Lane-Typen muessen lane=slow haben
  case "$STORY_TYPE" in
    platform-core|support-runtime|infra-factory)
      if [ "$STORY_LANE" != "slow" ]; then
        log "dispatch: FEHLER: $story_id hat story_type=$STORY_TYPE aber lane=$STORY_LANE (muss slow sein)"
        update_poller_state "$story_id" "governance-error"
        log_poller_event "$story_id" "governance_error" "story_type=$STORY_TYPE erfordert lane=slow"
        continue
      fi
      ;;
  esac

  # Lane in Metrik speichern
  record_metric "$story_id" "story_type" "'$STORY_TYPE'"
  record_metric "$story_id" "lane" "'$STORY_LANE'"

  # In Backlog verschieben
  DEST_DIR="$BACKLOG_DIR/by-product/$produkt"
  mkdir -p "$DEST_DIR"
  git mv "$story_file" "$DEST_DIR/$story_id.yml" 2>/dev/null || mv "$story_file" "$DEST_DIR/$story_id.yml"

  update_poller_state "$story_id" "backlog"
  record_metric "$story_id" "dispatched_at"
  record_metric "$story_id" "product" "'$produkt'"
  log_poller_event "$story_id" "dispatched" "Verschoben nach $DEST_DIR"
  log "dispatch: $story_id → $DEST_DIR"
done
shopt -u nullglob

# Änderungen pushen falls vorhanden
if git diff --cached --quiet && git diff --quiet; then
  log "dispatch: Keine Änderungen"
else
  git add -A
  git commit -m "dispatch: Stories in Backlog verschoben" 2>/dev/null || true
  git push origin main --quiet 2>/dev/null || true
fi

# ─── Phase 2: BRIDGE — Backlog → Feature-Branch + _task.md ────────────────
log "--- Phase 2: bridge ---"

cd "$WORK_DIR/process"
git pull --quiet origin main 2>/dev/null || true

mkdir -p work/04-in-progress
IN_PROGRESS_COUNT=$(find work/04-in-progress -name "*.yml" 2>/dev/null | wc -l | tr -d '[:space:]')
if [ "$IN_PROGRESS_COUNT" -gt "0" ]; then
  log "bridge: $IN_PROGRESS_COUNT Stories bereits in-progress — überspringe"
else
  # Erste Story im Backlog nehmen (nach Produkt sortiert)
  shopt -s nullglob
  for story_file in work/03-backlog/by-product/*/*.yml; do
    story_id=$(basename "$story_file" .yml)
    current_stage=$(get_poller_state "$story_id")

    if [ "$current_stage" = "backlog" ]; then
      log "bridge: $story_id → in-progress"

      # Story in in-progress verschieben
      git mv "$story_file" "work/04-in-progress/$story_id.yml" 2>/dev/null || \
        mv "$story_file" "work/04-in-progress/$story_id.yml"

      # Story-Daten lesen
      story_title=$( (grep '^title:' "work/04-in-progress/$story_id.yml" 2>/dev/null || true) | cut -d'"' -f2 | head -1)
      story_beschreibung=$( (awk '/^beschreibung:/,/^[a-z]/' "work/04-in-progress/$story_id.yml" 2>/dev/null || true) | \
        (grep '^\s*|' || true) | sed 's/^\s*|//' | head -10)
      : "${story_beschreibung:=Keine Beschreibung}"
      story_produkt=$( (grep '^produkt:' "work/04-in-progress/$story_id.yml" 2>/dev/null || true) | awk '{print $2}' | \
        tr -d '"'"'" | tr -d '[:space:]')
      : "${story_produkt:=$PRODUCT_REPO}"

      # Feature-Branch im Produkt-Repo erstellen
      BRANCH_NAME="feature/$(echo "$story_id" | tr '[:upper:]' '[:lower:]')-$(date +%s)"
      PROD_CLONE_URL="http://factory-admin:${FORGEJO_API_TOKEN}@localhost:3000/$FORGEJO_ORG/$story_produkt.git"

      if git clone --quiet "$PROD_CLONE_URL" "$WORK_DIR/$story_produkt" 2>/dev/null; then
        cd "$WORK_DIR/$story_produkt"
        git config user.name "Factory Poller"
        git config user.email "poller@factory.local"
        git checkout -b "$BRANCH_NAME" 2>/dev/null

        # _task.md erstellen
        AKZEPTANZKRITERIEN=$( (awk '/^akzeptanzkriterien:/,/^[a-z]/' "$WORK_DIR/process/work/04-in-progress/$story_id.yml" 2>/dev/null || true) | \
          (grep '^\s*-' || true) | sed 's/^\s*- /- /' | head -20)
        : "${AKZEPTANZKRITERIEN:=- Siehe Story}"

        # Governance-Felder lesen
        read_story_governance "$WORK_DIR/process/work/04-in-progress/$story_id.yml"

        cat > "_task.md" << TASKEOF
# Task: $story_id

## Titel
$story_title

## Beschreibung
$( (grep -A20 '^beschreibung:' "$WORK_DIR/process/work/04-in-progress/$story_id.yml" 2>/dev/null || true) | tail -n +2 | (grep '  ' || true) | sed 's/^  //' | head -20)
Implementiere die Story gemaess Akzeptanzkriterien.

## Akzeptanzkriterien
$AKZEPTANZKRITERIEN

## Metadaten
- Story-ID: $story_id
- Branch: $BRANCH_NAME
- Version: v$FACTORY_VERSION
- Story-Typ: $STORY_TYPE
- Lane: $STORY_LANE
- Founder Gate: $FOUNDER_GATE
TASKEOF

        git add _task.md
        git commit -m "$story_id: Task-Branch erstellt"
        git push origin "$BRANCH_NAME" --quiet 2>/dev/null

        cd "$WORK_DIR/process"
        update_poller_state "$story_id" "in-progress" "$BRANCH_NAME"
        record_metric "$story_id" "in_progress_at"
        log_poller_event "$story_id" "in_progress" "Branch $BRANCH_NAME erstellt"
        log "bridge: $story_id → Branch '$BRANCH_NAME' erstellt"
      else
        log "bridge: FEHLER beim Klonen von $story_produkt — überspringe $story_id"
      fi

      break  # Nur eine Story pro Durchlauf
    fi
  done
  shopt -u nullglob

  # Process-Repo aktualisieren
  cd "$WORK_DIR/process"
  if ! git diff --cached --quiet || ! git diff --quiet; then
    git add -A
    git commit -m "bridge: $story_id nach in-progress verschoben" 2>/dev/null || true
    git push origin main --quiet 2>/dev/null || true
  fi
fi

# ─── Phase 3: OPENCLAW — Feature-Branch → Aider + DeepSeek implementiert ────
log "--- Phase 3: openclaw via aider + deepseek ---"

AIDER_BIN="{{ aider_bin | default('/opt/aider-venv/bin/aider') }}"
OLLAMA_API_KEY="{{ vault_ollama_api_key }}"

# Alle in-progress Stories verarbeiten
shopt -s nullglob
for story_file in "$WORK_DIR/process/work/04-in-progress"/*.yml; do
  story_id=$(basename "$story_file" .yml)
  current_stage=$(get_poller_state "$story_id")

  if [ "$current_stage" != "in-progress" ] && [ "$current_stage" != "needs-fix" ]; then
    continue
  fi

  story_produkt=$( (grep '^produkt:' "$story_file" 2>/dev/null || true) | awk '{print $2}' | tr -d '"'"'" | tr -d '[:space:]')
  : "${story_produkt:=$PRODUCT_REPO}"

  BRANCH_NAME=$(get_scalar_sql "SELECT commit_hash FROM poller_state WHERE object_id='$(sql_escape "$story_id")'" 2>/dev/null || printf '')

  if [ -z "$BRANCH_NAME" ]; then
    log "openclaw: $story_id hat keinen Branch — ueberspringe"
    continue
  fi

  log "openclaw: $story_id stage=$current_stage branch=$BRANCH_NAME via aider+deepseek"

  # Repo klonen direkt auf Host
  IMPL_DIR=$(mktemp -d)
  PROD_CLONE_URL="http://factory-admin:${FORGEJO_API_TOKEN}@localhost:3000/$FORGEJO_ORG/$story_produkt.git"

  if ! git clone --quiet "$PROD_CLONE_URL" "$IMPL_DIR/$story_produkt" 2>/dev/null; then
    log "openclaw: $story_id — Klonen fehlgeschlagen — ueberspringe"
    rm -rf "$IMPL_DIR"
    continue
  fi

  cd "$IMPL_DIR/$story_produkt"
  git config user.name "Factory Junior"
  git config user.email "junior@factory.local"
  git checkout "$BRANCH_NAME" 2>/dev/null || git checkout -b "$BRANCH_NAME"

  # Prompt bestimmen
  if [ "$current_stage" = "needs-fix" ] && [ -f "_review.md" ]; then
    PROMPT="$(printf '## Original-Task\n\n'; cat _task.md; printf '\n\n## Review-Feedback - bitte alle Punkte beheben\n\n'; cat _review.md)"
    log "openclaw: $story_id — needs-fix Modus, _review.md wird einbezogen"
  else
    PROMPT="$(cat _task.md)"
  fi

  run_aider_task() {
    cd "$IMPL_DIR/$story_produkt"
    OPENAI_API_BASE=https://ollama.com/v1 \
    OPENAI_API_KEY="$OLLAMA_API_KEY" \
    $AIDER_BIN \
      --model openai/{{ impl_model | default('deepseek-v3.1:671b') }} \
      --message "$PROMPT" \
      --yes \
      --no-stream \
      --auto-commits \
      --no-show-model-warnings \
      2>&1 | tee -a "$LOGFILE"
    git push origin "$BRANCH_NAME" --quiet 2>/dev/null
  }

  if retry_with_backoff 3 "openclaw:$story_id" run_aider_task; then
    update_poller_state "$story_id" "openclaw-done" "$BRANCH_NAME"
    log_poller_event "$story_id" "openclaw-done" "Implementierung abgeschlossen via aider+deepseek"
    log "openclaw: $story_id Implementierung abgeschlossen"
  else
    update_poller_state "$story_id" "openclaw-error" "$BRANCH_NAME"
    log_poller_event "$story_id" "retry_exhausted" "Fehlgeschlagen nach 3 Versuchen"
    record_metric "$story_id" "blocked_at"
    record_metric "$story_id" "blocked_reason" "'retry_exhausted'"
    record_metric "$story_id" "retry_count" "3"
    log "openclaw: $story_id Fehler nach 3 Versuchen"
  fi

  rm -rf "$IMPL_DIR"
  cd "$WORK_DIR/process"
done
shopt -u nullglob

# ─── Phase 3b: REVIEW — Opus reviewed, bei Schwaechen Fix-Schleife ────────
log "--- Phase 3b: review ---"

shopt -s nullglob
for story_file in "$WORK_DIR/process/work/04-in-progress"/*.yml; do
  story_id=$(basename "$story_file" .yml)
  current_stage=$(get_poller_state "$story_id")

  if [ "$current_stage" != "openclaw-done" ]; then
    continue
  fi

  story_produkt=$( (grep '^produkt:' "$story_file" 2>/dev/null || true) | awk '{print $2}' | tr -d '"'"'" | tr -d '[:space:]')
  : "${story_produkt:=$PRODUCT_REPO}"

  BRANCH_NAME=$(get_scalar_sql "SELECT commit_hash FROM poller_state WHERE object_id='$(sql_escape "$story_id")'" 2>/dev/null || printf '')

  if [ -z "$BRANCH_NAME" ]; then
    continue
  fi

  # Review-Iterationen pruefen
  REVIEW_ITERS=$(get_scalar_sql "SELECT COALESCE(review_iterations, 0) FROM pipeline_metrics WHERE object_id='$(sql_escape "$story_id")'" 2>/dev/null || printf '')
  REVIEW_ITERS=${REVIEW_ITERS:-0}

  # Governance-Felder lesen
  read_story_governance "$story_file"

  if [ "$REVIEW_ITERS" -ge "{{ max_review_iterations }}" ]; then
    if [ "$FORCE_APPROVE" = "false" ]; then
      # Slow Lane: Force-Approve VERBOTEN → Story blockieren
      log "review: $story_id — Max-Iterationen erreicht, aber force_approve_allowed=false → BLOCKIERT"
      update_poller_state "$story_id" "blocked-needs-po"
      record_metric "$story_id" "blocked_at"
      record_metric "$story_id" "blocked_reason" "'force-approve-denied'"
      log_poller_event "$story_id" "blocked" "Max-Iterationen, force_approve nicht erlaubt (lane=$STORY_LANE)"

      # Story in needs-po verschieben
      cd "$WORK_DIR/process"
      BLOCKED_DIR="work/09-blocked/needs-po"
      mkdir -p "$BLOCKED_DIR"
      if [ -f "work/04-in-progress/$story_id.yml" ]; then
        git mv "work/04-in-progress/$story_id.yml" "$BLOCKED_DIR/$story_id.yml" 2>/dev/null || \
          mv "work/04-in-progress/$story_id.yml" "$BLOCKED_DIR/$story_id.yml"
        git add -A
        git commit -m "review: $story_id blockiert — Founder Gate erforderlich" 2>/dev/null || true
        git push origin main --quiet 2>/dev/null || true
      fi
    else
      # Fast Lane: Force-Approve erlaubt
      log "review: $story_id — Max-Iterationen ({{ max_review_iterations }}) erreicht → force-approve"
      update_poller_state "$story_id" "reviewed" "$BRANCH_NAME"
      record_metric "$story_id" "review_verdict" "'force-approved'"
      record_metric "$story_id" "review_completed_at"
      log_poller_event "$story_id" "force_approved" "Max-Iterationen erreicht ($REVIEW_ITERS)"
    fi
    continue
  fi

  log "review: $story_id → Branch $BRANCH_NAME → Opus Review (Iteration $((REVIEW_ITERS + 1)))"

  # Review-Start markieren
  if [ "$REVIEW_ITERS" -eq "0" ]; then
    record_metric "$story_id" "review_started_at"
  fi

  # Repo klonen und Diff erstellen
  REVIEW_DIR=$(mktemp -d)
  PROD_CLONE_URL="http://factory-admin:${FORGEJO_API_TOKEN}@localhost:3000/$FORGEJO_ORG/$story_produkt.git"

  if ! git clone --quiet "$PROD_CLONE_URL" "$REVIEW_DIR/$story_produkt" 2>/dev/null; then
    log "review: $story_id — Klonen fehlgeschlagen — überspringe"
    rm -rf "$REVIEW_DIR"
    continue
  fi

  cd "$REVIEW_DIR/$story_produkt"
  git checkout "$BRANCH_NAME" 2>/dev/null || { log "review: Branch $BRANCH_NAME nicht gefunden"; cd "$WORK_DIR/process"; rm -rf "$REVIEW_DIR"; continue; }

  DIFF=$(git diff main...HEAD 2>/dev/null | head -c 51200)
  TASK_CONTENT=$(cat _task.md 2>/dev/null || echo "Keine _task.md gefunden")

  # Review-Prompt bauen
  REVIEW_PROMPT="Du bist ein Senior Code-Reviewer. Pruefe den folgenden Diff gegen die Task-Beschreibung.

## Pruefkriterien
1. **Korrektheit**: Erfuellt der Code alle Akzeptanzkriterien?
2. **Tests**: Sind ausreichend Tests vorhanden?
3. **Sicherheit**: Keine Injection, XSS, oder andere Schwachstellen?
4. **Qualitaet**: Sauberer Code, keine offensichtlichen Bugs?

## Task
${TASK_CONTENT}

## Diff
\`\`\`diff
${DIFF}
\`\`\`

## Antwortformat
Antworte mit GENAU einer der folgenden Zeilen am Ende:
- VERDICT: APPROVED (wenn alles in Ordnung ist)
- VERDICT: NEEDS_FIX (wenn Aenderungen noetig sind)

Bei NEEDS_FIX: Liste vorher die konkreten Probleme und Loesungsvorschlaege auf."

  # Review via Ollama.com API - DeepSeek, kein Docker noetig
  REVIEW_PROMPT_FILE="/tmp/review-prompt-${story_id}.txt"
  echo "$REVIEW_PROMPT" > "$REVIEW_PROMPT_FILE"

  REVIEW_PROMPT_JSON=$(python3 -c "import sys,json; print(json.dumps(open(sys.argv[1]).read()))" "$REVIEW_PROMPT_FILE")

  REVIEW_OUTPUT=$(curl -sf --max-time 300 \
    -H "Authorization: Bearer $OLLAMA_API_KEY" \
    -H "Content-Type: application/json" \
    -d "{\"model\": \"{{ review_model | default('deepseek-v3.1:671b') }}\", \"messages\": [{\"role\": \"user\", \"content\": $REVIEW_PROMPT_JSON}], \"max_tokens\": 4096, \"stream\": false}" \
    "https://ollama.com/v1/chat/completions" 2>/dev/null \
    | python3 -c 'import sys,json; r=json.load(sys.stdin); print(r["choices"][0]["message"]["content"])' 2>/dev/null \
    || echo "REVIEW_ERROR")
  rm -f "$REVIEW_PROMPT_FILE"

  # Verdict parsen
  VERDICT=$(echo "$REVIEW_OUTPUT" | sed -n 's/.*VERDICT:[[:space:]]*\([A-Z_]*\).*/\1/p' | tail -1)

  if [ "$VERDICT" = "APPROVED" ]; then
    log "review: $story_id — APPROVED"
    update_poller_state "$story_id" "reviewed" "$BRANCH_NAME"
    record_metric "$story_id" "review_iterations" "$((REVIEW_ITERS + 1))"
    record_metric "$story_id" "review_verdict" "'approved'"
    record_metric "$story_id" "review_completed_at"
    log_poller_event "$story_id" "review_approved" "Approved nach Iteration $((REVIEW_ITERS + 1))"
  elif [ "$VERDICT" = "NEEDS_FIX" ]; then
    log "review: $story_id — NEEDS_FIX (Iteration $((REVIEW_ITERS + 1)))"

    # _review.md auf Branch schreiben
    cd "$REVIEW_DIR/$story_produkt"
    echo "$REVIEW_OUTPUT" > _review.md
    git add _review.md
    git commit -m "${story_id}: Review-Feedback (Iteration $((REVIEW_ITERS + 1)))" 2>/dev/null || true
    git push origin "$BRANCH_NAME" --quiet 2>/dev/null || true

    update_poller_state "$story_id" "needs-fix" "$BRANCH_NAME"
    record_metric "$story_id" "review_iterations" "$((REVIEW_ITERS + 1))"
    record_metric "$story_id" "review_verdict" "'needs-fix'"
    log_poller_event "$story_id" "review_needs_fix" "Iteration $((REVIEW_ITERS + 1))"
  else
    log "review: $story_id — Verdict nicht parsebar → force-approve"
    log "review: Output (letzte 200 Zeichen): $(echo "$REVIEW_OUTPUT" | tail -c 200)"
    update_poller_state "$story_id" "reviewed" "$BRANCH_NAME"
    record_metric "$story_id" "review_iterations" "$((REVIEW_ITERS + 1))"
    record_metric "$story_id" "review_verdict" "'force-approved'"
    record_metric "$story_id" "review_completed_at"
    log_poller_event "$story_id" "force_approved" "Verdict nicht parsebar"
  fi

  cd "$WORK_DIR/process"
  rm -rf "$REVIEW_DIR"
done
shopt -u nullglob

# ─── Phase 4: PR-CHECK — PR erstellen falls noch keiner existiert ──────────
log "--- Phase 4: pr-check ---"

shopt -s nullglob
for story_file in "$WORK_DIR/process/work/04-in-progress"/*.yml; do
  story_id=$(basename "$story_file" .yml)
  current_stage=$(get_poller_state "$story_id")

  if [ "$current_stage" != "reviewed" ]; then
    continue
  fi

  story_produkt=$( (grep '^produkt:' "$story_file" 2>/dev/null || true) | awk '{print $2}' | tr -d '"'"'" | tr -d '[:space:]')
  : "${story_produkt:=$PRODUCT_REPO}"

  story_title=$( (grep '^title:' "$story_file" 2>/dev/null || true) | cut -d'"' -f2 | head -1)
  # Sonderzeichen in story_title escapen fuer JSON
  story_title_safe=$(printf '%s' "$story_title" | sed 's/\\/\\\\/g; s/"/\\"/g')

  BRANCH_NAME=$(get_scalar_sql "SELECT commit_hash FROM poller_state WHERE object_id='$(sql_escape "$story_id")'" 2>/dev/null || printf '')

  if [ -z "$BRANCH_NAME" ]; then
    continue
  fi

  log "pr-check: $story_id → PR erstellen für Branch $BRANCH_NAME"

  # Prüfe ob PR bereits existiert
  EXISTING_PR=$(forgejo_api \
    "$FORGEJO_URL/api/v1/repos/$FORGEJO_ORG/$story_produkt/pulls?state=open&head=$BRANCH_NAME" \
    2>/dev/null | jq '. | length' 2>/dev/null || echo "0")

  if [ "$EXISTING_PR" -gt "0" ]; then
    log "pr-check: $story_id — PR existiert bereits"
    update_poller_state "$story_id" "pr_created" "$BRANCH_NAME"
    record_metric "$story_id" "pr_created_at"
    continue
  fi

  # PR erstellen
  PR_RESULT=$(forgejo_api \
    -X POST \
    -d "{
      \"title\": \"$story_id: $story_title_safe\",
      \"body\": \"Automatisch erstellt durch Code-Fabrik v$FACTORY_VERSION\\n\\nStory: $story_id\",
      \"head\": \"$BRANCH_NAME\",
      \"base\": \"main\"
    }" \
    "$FORGEJO_URL/api/v1/repos/$FORGEJO_ORG/$story_produkt/pulls" 2>/dev/null)

  PR_NUMBER=$(echo "$PR_RESULT" | jq -r '.number // "?"' 2>/dev/null)
  if [ "$PR_NUMBER" != "?" ] && [ -n "$PR_NUMBER" ]; then
    log "pr-check: $story_id → PR #$PR_NUMBER erstellt"
    update_poller_state "$story_id" "pr_created" "$BRANCH_NAME"
    record_metric "$story_id" "pr_created_at"
    log_poller_event "$story_id" "pr_created" "PR #$PR_NUMBER"

    # Governance-Felder lesen
    read_story_governance "$story_file"

    if [ "$AUTO_MERGE" = "true" ]; then
      # Fast Lane: Auto-Merge
      log "pr-check: $story_id — Auto-Merge (lane=$STORY_LANE)"
      forgejo_api \
        -X POST \
        "$FORGEJO_URL/api/v1/repos/$FORGEJO_ORG/$story_produkt/pulls/$PR_NUMBER/merge" \
        -d "{\"Do\": \"merge\", \"merge_message_field\": \"$story_id: Auto-Merge (Fast Lane)\"}" \
        2>/dev/null || log "pr-check: Auto-Merge fehlgeschlagen fuer PR #$PR_NUMBER"

      # Story nach done verschieben
      cd "$WORK_DIR/process"
      DONE_DIR="work/08-done"
      mkdir -p "$DONE_DIR"
      if [ -f "work/04-in-progress/$story_id.yml" ]; then
        git mv "work/04-in-progress/$story_id.yml" "$DONE_DIR/$story_id.yml" 2>/dev/null || \
          mv "work/04-in-progress/$story_id.yml" "$DONE_DIR/$story_id.yml"
        git add -A
        git commit -m "done: $story_id (Auto-Merge, Fast Lane)" 2>/dev/null || true
        git push origin main --quiet 2>/dev/null || true
      fi
      update_poller_state "$story_id" "done" "$BRANCH_NAME"
      record_metric "$story_id" "completed_at"
      log_poller_event "$story_id" "done" "Auto-Merge PR #$PR_NUMBER"
    else
      # Slow Lane: PR wartet auf Founder Gate
      log "pr-check: $story_id — Slow Lane, PR #$PR_NUMBER wartet auf Founder Gate"

      # Label erstellen (ignoriert Fehler wenn bereits vorhanden)
      forgejo_api \
        -X POST \
        "$FORGEJO_URL/api/v1/repos/$FORGEJO_ORG/$story_produkt/labels" \
        -d '{"name": "awaiting-founder-gate", "color": "#e11d48"}' \
        2>/dev/null || true

      # Label an PR haengen
      forgejo_api \
        -X POST \
        "$FORGEJO_URL/api/v1/repos/$FORGEJO_ORG/$story_produkt/issues/$PR_NUMBER/labels" \
        -d '{"labels": ["awaiting-founder-gate"]}' \
        2>/dev/null || true

      log_poller_event "$story_id" "awaiting_founder_gate" "PR #$PR_NUMBER wartet auf PO"
    fi
  else
    log "pr-check: $story_id → PR-Erstellung fehlgeschlagen: $PR_RESULT"
  fi
done
shopt -u nullglob

# ─── Retention: Alte Events aufräumen (>30 Tage) ─────────────────────────────
run_psql -c "DELETE FROM poller_events WHERE created_at < NOW() - INTERVAL '30 days';" >/dev/null 2>&1 || true

log "=== Poller v$FACTORY_VERSION abgeschlossen ==="
